# LLM credentials for the SG Nutrition Investigator example.
# Copy to .env (gitignored) and fill in your key. The Makefile auto-loads .env
# and exports these to the agent. .env overrides any matching shell variable.
#
#   cp .env.example .env

# Your LiteLLM proxy key (or an OpenAI key if you point OPENAI_BASE_URL at OpenAI).
OPENAI_API_KEY=sk-your-proxy-key-here

# The proxy base URL. Leave blank to use api.openai.com.
OPENAI_BASE_URL=https://litellm-stg.aip.gov.sg

# The model name the proxy serves.
OPENAI_MODEL=gpt-5.4
