# Turnkey compose configuration. Copy to .env and fill secrets, OR just run
#   make compose-init
# which generates strong values for the three RUNTIME_* secrets below.
#
# .env is gitignored — never commit real values.

# --- Secrets (generated by `make compose-init`) -------------------------------
# Superuser break-glass service key. Use it to log into the console and create
# the first tenant + tenant-admin. Treat as root.
RUNTIME_ADMIN_BOOTSTRAP=replace-me-run-make-compose-init
# Secrets broker AES key(s): "<id>:<base64-32-byte-key>". PRIMARY names the id
# new secrets seal under and MUST match an id in KEYS.
RUNTIME_SECRETS_KEYS=primary:replace-me-base64-32-bytes
RUNTIME_SECRETS_PRIMARY=primary

# --- Tunables (sane defaults; override only if needed) ------------------------
# Embedding model + dim for semantic Memory (served by the bundled embedder).
RUNTIME_EMBED_MODEL=bge-small-en-v1.5
RUNTIME_EMBED_DIM=384
# Recall similarity floor, tuned for the bundled bge-small model (see Task 8).
RUNTIME_EMBED_RECALL_FLOOR=0.60
# Host docker group GID, so the non-root runtimed can read the mounted docker
# socket and launch sandbox/browser containers (native Linux only; harmless on
# Docker Desktop). Find yours: `getent group docker | cut -d: -f3`.
DOCKER_GID=999

# --- Persistence --------------------------------------------------------------
# Data lives in named volumes (pgdata). `docker compose down` PRESERVES data;
# `docker compose down -v` RESETS everything (and re-runs the pgvector init).
